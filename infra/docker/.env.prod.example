# Copie este archivo a .env.prod y ajuste secretos y hosts antes de arrancar produccion.

APP_NAME=Cimiento
DEBUG=false

POSTGRES_USER=cimiento
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=cimiento
DATABASE_URL=postgresql+asyncpg://cimiento:change_me_in_production@postgres:5432/cimiento

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=normativa

# Por defecto se asume Ollama ejecutandose en el host.
# Si quiere Ollama en contenedor, cambie este valor a http://ollama:11434
# y arranque Compose con --profile ollama.
OLLAMA_HOST=http://host.docker.internal:11434

SOLVER_TIMEOUT_SECONDS=60

BLENDER_EXECUTABLE=blender
RENDER_SAMPLES=64
RENDER_WIDTH=2048
RENDER_HEIGHT=1152
RENDER_TIMEOUT_SECONDS=600

FRONTEND_PORT=8080